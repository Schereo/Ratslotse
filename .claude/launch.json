{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev",
        "--prefix",
        "web/frontend"
      ],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "docs",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "preview",
        "--prefix",
        "docs-site"
      ],
      "port": 4321
    }
  ]
}