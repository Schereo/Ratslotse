[Unit]
Description=NWZ-Bot Web API (FastAPI/uvicorn)
After=network.target

[Service]
Type=simple
User=<user>
WorkingDirectory=/home/<user>/app/web/backend
EnvironmentFile=/home/<user>/app/.env
ExecStart=/home/<user>/app/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
